def add_asm_constraint(c_type: str, comp1: str, geom1: str, comp2: str, geom2: str, value: float=0) -> str:
    """添加装配约束：AI 核心装配能力，支持所有主流约束
    c_type: coincident(重合) / parallel(平行) / perpendicular(垂直) / distance(距离) / angle(角度)
    geom1/geom2: 约束几何（face/edge/axis/origin）
    """
    try:
        # 获取组件
        occ1 = root_comp.occurrences.itemByName(comp1)
        occ2 = root_comp.occurrences.itemByName(comp2)
        if not occ1 or not occ2:
            return f"失败：组件[{comp1}]或[{comp2}]不存在"
        # 映射约束类型/几何
        c_map = {
            "coincident": adsk.fusion.AsstConstraintTypes.CoincidentConstraintType,
            "parallel": adsk.fusion.AsstConstraintTypes.ParallelConstraintType,
            "perpendicular": adsk.fusion.AsstConstraintTypes.PerpendicularConstraintType,
            "distance": adsk.fusion.AsstConstraintTypes.DistanceConstraintType,
            "angle": adsk.fusion.AsstConstraintTypes.AngleConstraintType
        }
        geom_map = {"face": 0, "edge": 1, "axis": 2, "origin": 3}
        if c_type not in c_map or geom1 not in geom_map or geom2 not in geom_map:
            return f"失败：约束类型/几何不支持"
        # 获取约束几何（默认取第一个面/边/轴）
        def get_geom(occ, g_type):
            if g_type == "face": return occ.component.bRepBodies.item(0).faces.item(0)
            elif g_type == "edge": return occ.component.bRepBodies.item(0).edges.item(0)
            elif g_type == "axis": return occ.component.xAxis
            elif g_type == "origin": return occ.component.originPoint
        geom1_obj = get_geom(occ1, geom1)
        geom2_obj = get_geom(occ2, geom2)
        # 创建约束
        asm_constraints = root_comp.assemblyConstraints
        if c_type in ["distance", "angle"]:
            const_input = asm_constraints.createInput(
                c_map[c_type],
                adsk.core.ValueInput.createByReal(value if c_type=="distance" else math.radians(value))
            )
        else:
            const_input = asm_constraints.createInput(c_map[c_type])
        const_input.setGeometry(geom1_obj, occ1, geom2_obj, occ2)
        asm_constraints.add(const_input)
        return f"成功：添加{c_type}约束，[{comp1}({geom1})]→[{comp2}({geom2})]，值{value}"
    except:
        return f"添加装配约束失败：{traceback.format_exc()}"

