def create_drawing(dwg_name: str, sheet_size: str = "A4") -> str:
    """创建工程图：指定名称/图纸尺寸（A4/A3/A2/A1/A0）"""
    try:
        # 创建工程图文档
        dwg_doc = app.documents.add(adsk.core.DocumentTypes.DrawingDocumentType)
        drawing = adsk.fusion.Drawing.cast(dwg_doc.activeProduct)
        # 设置图纸尺寸
        sheet = drawing.sheets.item(0)
        sheet.name = dwg_name
        size_map = {"A4": (210,297), "A3": (297,420), "A2": (420,594), "A1": (594,841), "A0": (841,1189)}
        if sheet_size in size_map:
            sheet.width = size_map[sheet_size][0]
            sheet.height = size_map[sheet_size][1]
        return f"成功：创建工程图[{dwg_name}]，尺寸{sheet_size}，已切换到工程图模式"
    except:
        return f"创建工程图失败：{traceback.format_exc()}"

def add_drawing_view(view_type: str, dwg_name: str, x: float=50, y: float=50, scale: float=1.0) -> str:
    """添加工程图视图：指定视图类型/图纸名/位置/比例
    view_type: front(主视图) / top(俯视图) / right(右视图) / isometric(等轴测)
    """
    try:
        drawing = adsk.fusion.Drawing.cast(app.activeProduct)
        sheet = drawing.sheets.itemByName(dwg_name)
        if not sheet:
            return f"失败：图纸[{dwg_name}]不存在"
        # 映射视图类型
        view_map = {
            "front": adsk.fusion.ViewTypes.FrontViewType,
            "top": adsk.fusion.ViewTypes.TopViewType,
            "right": adsk.fusion.ViewTypes.RightViewType,
            "isometric": adsk.fusion.ViewTypes.IsometricViewType
        }
        if view_type not in view_map:
            return f"失败：视图类型仅支持front/top/right/isometric"
        # 添加视图
        view_input = sheet.views.createInput(design, view_map[view_type])
        view_input.position = adsk.core.Point2D.create(x, y)
        view_input.scale = scale
        sheet.views.add(view_input)
        return f"成功：添加{view_type}视图，位置({x},{y})，比例{scale}:1"
    except:
        return f"添加视图失败：{traceback.format_exc()}"

def auto_dimension(dwg_name: str, view_name: str) -> str:
    """自动尺寸标注：指定图纸/视图，AI 自动标注所有尺寸"""
    try:
        drawing = adsk.fusion.Drawing.cast(app.activeProduct)
        sheet = drawing.sheets.itemByName(dwg_name)
        view = sheet.views.itemByName(view_name)
        if not sheet or not view:
            return f"失败：图纸[{dwg_name}]或视图[{view_name}]不存在"
        # 自动标注线性/径向/角度尺寸
        dims = view.dimensions
        dims.autoDimension(True, True, True)
        return f"成功：为[{view_name}]自动标注所有尺寸（线性/径向/角度）"
    except:
        return f"自动标注失败：{traceback.format_exc()}"

def export_model(file_path: str, file_type: str = "step") -> str:
    """全格式导出：指定路径/格式，支持建模/装配/工程图导出
    file_type: step/stl/iges/sat/f3d/pdf/dxf (覆盖所有工业格式)
    """
    try:
        export_mgr = design.exportManager if design else adsk.fusion.Drawing.cast(app.activeProduct).exportManager
        # 映射导出格式
        if file_type == "step":
            opt = export_mgr.createSTEPExportOptions(file_path)
        elif file_type == "stl":
            opt = export_mgr.createSTLExportOptions(file_path)
            opt.isBinary = True  # 二进制STL，体积更小
        elif file_type == "iges":
            opt = export_mgr.createIGESExportOptions(file_path)
        elif file_type == "sat":
            opt = export_mgr.createSATExportOptions(file_path)
        elif file_type == "f3d":
            app.activeDocument.saveAs(file_path, adsk.core.SaveAsTypes.FusionSaveAsType)
            return f"成功：导出F3D文件到[{file_path}]"
        elif file_type == "pdf":
            opt = export_mgr.createPDFExportOptions(file_path)
        elif file_type == "dxf":
            opt = export_mgr.createDXFExportOptions(file_path)
        else:
            return f"失败：导出格式仅支持step/stl/iges/sat/f3d/pdf/dxf"
        export_mgr.execute(opt)
        return f"成功：导出{file_type.upper()}文件到[{file_path}]"
    except:
        return f"导出失败：{traceback.format_exc()}"

def batch_export(comp_names: List[str], save_path: str, file_type: str = "step") -> str:
    """AI 批量导出：指定组件列表/保存路径/格式，一次性导出多个零件"""
    try:
        success_count = 0
        for comp in comp_names:
            if comp in obj_cache["assemblies"]:
                # 切换到组件并导出
                design.activeComponent = root_comp.occurrences.itemByName(comp).component
                file_path = f"{save_path}/{comp}.{file_type.lower()}"
                export_model(file_path, file_type)
                success_count +=1
        return f"批量导出完成：成功{success_count}个，总{len(comp_names)}个，保存路径[{save_path}]"
    except:
        return f"批量导出失败：{traceback.format_exc()}"

# ==========================
# 模块8：AI Agent 标准化调用封装（JSON Schema，适配所有Agent）
# ==========================
def tool_call(call_data: Dict[str, Any]) -> Dict[str, Any]:
    """
    AI Agent 标准化工具调用入口：传入JSON，统一返回JSON
    call_data示例：
    {
        "tool_name": "create_box",
        "params": {"name": "base", "x": 50, "y": 50, "z": 20}
    }
    """
    try:
        tool_name = call_data.get("tool_name")
        params = call_data.get("params", {})
        # 映射工具函数
        tool_map = {
            "init_design": init_design,
            "get_scene_info": get_scene_info,
            "create_sketch": create_sketch,
            "create_box": create_box,
            "create_cylinder": create_cylinder,
            "create_sphere": create_sphere,
            "extrude": extrude,
            "revolve": revolve,
            "sweep": sweep,
            "loft": loft,
            "create_shell": create_shell,
            "create_fillet": create_fillet,
            "boolean_operation": boolean_operation,
            "create_param": create_param,
            "modify_param": modify_param,
            "create_component": create_component,
            "add_asm_constraint": add_asm_constraint,
            "create_drawing": create_drawing,
            "export_model": export_model,
            "batch_export": batch_export
        }
        if tool_name not in tool_map:
            return {"status": "error", "msg": f"工具[{tool_name}]不存在"}
        # 执行工具并返回结果
        result = tool_map[tool_name](**params)
        return {
            "status": "success" if not ("失败" in str(result)) else "error",
            "tool_name": tool_name,
            "params": params,
            "result": result,
            "obj_cache": obj_cache  # 返给AI最新对象缓存
        }
    except:
        return {
            "status": "error",
            "tool_name": call_data.get("tool_name"),
            "msg": f"工具调用失败：{traceback.format_exc()}"
        }