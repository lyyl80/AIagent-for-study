def create_param(name: str, value: float, unit: str = "mm", expr: str = "") -> str:
    """创建全局用户参数：指定名称/值/单位/表达式（支持参数关联）"""
    try:
        if hasattr(design.userParameters, name):
            return f"失败：参数[{name}]已存在"
        param = design.userParameters.add(
            name, adsk.core.ValueInput.createByReal(value), unit, expr
        )
        return f"成功：创建参数[{name}] = {value}{unit}，表达式[{expr}]"
    except:
        return f"创建参数失败：{traceback.format_exc()}"

def modify_param(name: str, value: float) -> str:
    """修改全局参数：指定名称/新值，模型自动联动更新（AI 核心参数化能力）"""
    try:
        param = design.userParameters.itemByName(name)
        if not param:
            return f"失败：参数[{name}]不存在"
        param.value = value
        # 刷新模型
        design.refresh()
        return f"成功：修改参数[{name}] = {value}{param.unit}，模型已自动更新"
    except:
        return f"修改参数失败：{traceback.format_exc()}"

def link_param(feat_name: str, param_name: str, param_type: str = "distance") -> str:
    """参数关联：将特征尺寸与全局参数绑定（如拉伸深度→全局参数）"""
    try:
        feat = select_obj("feature", feat_name)
        param = design.userParameters.itemByName(param_name)
        if not feat or not param:
            return f"失败：特征[{feat_name}]或参数[{param_name}]不存在"
        # 绑定拉伸/旋转/圆角等常见特征尺寸
        if param_type == "distance" and hasattr(feat, "extentOne"):
            feat.extentOne.distance.value = param.value
        elif param_type == "radius" and hasattr(feat, "radius"):
            feat.radius.value = param.value
        elif param_type == "angle" and hasattr(feat, "angle"):
            feat.angle.value = param.value
        design.refresh()
        return f"成功：将[{feat_name}]的{param_type}与参数[{param_name}]绑定"
    except:
        return f"参数关联失败：{traceback.format_exc()}"

