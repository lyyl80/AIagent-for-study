# -*- coding: utf-8 -*-
# Fusion360 AI Agent 终极建模工具库
# 覆盖：建模/装配/工程图/感知/参数化/导出/批量/标准化
import adsk.core, adsk.fusion, traceback, math
from typing import List, Dict, Any

# 全局核心对象（Fusion360 固定初始化）
app = adsk.core.Application.get()
ui = app.userInterface
design = app.activeProduct
root_comp = design.rootComponent if design else None
features = root_comp.features if root_comp else None
sketches = root_comp.sketches if root_comp else None
# 全局缓存：存储草图/体/特征ID，方便AI调用
obj_cache: Dict[str, Any] = {"sketches": {}, "bodies": {}, "features": {}, "assemblies": {}}

# ==========================
# 模块1：基础初始化/场景感知（AI 核心能力：知当前模型状态）
# ==========================
def init_design() -> str:
    """初始化新设计，清空所有内容"""
    try:
        global design, root_comp, features, sketches
        app.documents.add(adsk.core.DocumentTypes.FusionDesignDocumentType)
        design = app.activeProduct
        root_comp = design.rootComponent
        features = root_comp.features
        sketches = root_comp.sketches
        obj_cache.clear()
        obj_cache.update({"sketches": {}, "bodies": {}, "features": {}, "assemblies": {}})
        return "设计已初始化，新空白工程创建完成"
    except:
        return f"初始化失败：{traceback.format_exc()}"

def get_scene_info() -> Dict[str, Any]:
    """AI 场景感知：获取当前模型所有信息（返回JSON，AI可解析）"""
    try:
        if not root_comp:
            return {"status": "error", "msg": "无激活设计"}
        # 提取体信息
        bodies_info = []
        for i, body in enumerate(root_comp.bRepBodies):
            bodies_info.append({
                "id": body.id,
                "name": body.name,
                "type": "solid" if body.isSolid else "surface",
                "volume": body.volume if body.isSolid else 0,
                "face_count": body.faces.count,
                "edge_count": body.edges.count
            })
            obj_cache["bodies"][body.name] = body.id
        # 提取草图信息
        sketches_info = []
        for i, sketch in enumerate(root_comp.sketches):
            sketches_info.append({
                "id": sketch.id,
                "name": sketch.name,
                "plane": sketch.referencePlane.name if sketch.referencePlane else "unknown",
                "curve_count": sketch.sketchCurves.count,
                "profile_count": sketch.profiles.count
            })
            obj_cache["sketches"][sketch.name] = sketch.id
        # 提取特征信息
        features_info = []
        for i, feat in enumerate(root_comp.features):
            features_info.append({
                "id": feat.id,
                "name": feat.name,
                "type": feat.objectType.split(".")[-1]
            })
            obj_cache["features"][feat.name] = feat.id
        # 提取参数信息
        params_info = []
        for param in design.userParameters:
            params_info.append({
                "name": param.name,
                "value": param.value,
                "unit": param.unit,
                "expression": param.expression
            })
        # 提取装配信息
        asm_info = {"component_count": design.allComponents.count}
        # 组合返回
        scene_info = {
            "status": "success",
            "design_name": app.activeDocument.name,
            "bodies": bodies_info,
            "sketches": sketches_info,
            "features": features_info,
            "parameters": params_info,
            "assembly": asm_info,
            "obj_cache": obj_cache  # 给AI的对象缓存，方便直接调用
        }
        return scene_info
    except:
        return {"status": "error", "msg": f"获取场景信息失败：{traceback.format_exc()}"}

def select_obj(obj_type: str, obj_name: str) -> Any:
    """AI 选择对象：根据类型/名称获取对象（封装选择逻辑，AI无需懂底层）"""
    try:
        if obj_type == "body" and obj_name in obj_cache["bodies"]:
            return root_comp.findEntityById(obj_cache["bodies"][obj_name])
        elif obj_type == "sketch" and obj_name in obj_cache["sketches"]:
            return root_comp.findEntityById(obj_cache["sketches"][obj_name])
        elif obj_type == "feature" and obj_name in obj_cache["features"]:
            return root_comp.findEntityById(obj_cache["features"][obj_name])
        else:
            return None
    except:
        return None

# ==========================
# 模块2：草图绘制（基础+批量，支持AI精准定位）
# ==========================
def create_sketch(plane_name: str, sketch_name: str = "sketch") -> str:
    """创建草图，指定平面/名称，自动加入缓存"""
    try:
        if plane_name == "xy":
            plane = root_comp.xYConstructionPlane
        elif plane_name == "yz":
            plane = root_comp.yZConstructionPlane
        elif plane_name == "xz":
            plane = root_comp.xZConstructionPlane
        else:
            return f"失败：平面仅支持xy/yz/xz"
        sketch = sketches.add(plane)
        sketch.name = sketch_name
        obj_cache["sketches"][sketch_name] = sketch.id
        return f"成功：创建{plane_name}草图[{sketch_name}]，ID={sketch.id}"
    except:
        return f"创建草图失败：{traceback.format_exc()}"

def draw_circle(sketch_name: str, x: float, y: float, radius: float) -> str:
    """绘制圆形：指定草图/圆心坐标/半径"""
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch:
            return f"失败：草图[{sketch_name}]不存在"
        sketch.sketchCurves.sketchCircles.addByCenterRadius(
            adsk.core.Point3D.create(x, y, 0), radius
        )
        return f"成功：在[{sketch_name}]绘制圆(中心{x},{y}，半径{radius})"
    except:
        return f"绘制圆失败：{traceback.format_exc()}"

def draw_rect(sketch_name: str, x1: float, y1: float, x2: float, y2: float) -> str:
    """绘制矩形：指定草图/对角坐标"""
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch:
            return f"失败：草图[{sketch_name}]不存在"
        sketch.sketchCurves.sketchLines.addTwoPointRectangle(
            adsk.core.Point3D.create(x1, y1, 0),
            adsk.core.Point3D.create(x2, y2, 0)
        )
        return f"成功：在[{sketch_name}]绘制矩形({x1},{y1})→({x2},{y2})"
    except:
        return f"绘制矩形失败：{traceback.format_exc()}"

def draw_polygon(sketch_name: str, x: float, y: float, radius: float, sides: int) -> str:
    """绘制正多边形：指定草图/中心/外接圆半径/边数"""
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch:
            return f"失败：草图[{sketch_name}]不存在"
        sketch.sketchCurves.sketchPolygons.add(
            adsk.core.Point3D.create(x, y, 0), radius, sides
        )
        return f"成功：在[{sketch_name}]绘制{sides}边形(中心{x},{y}，半径{radius})"
    except:
        return f"绘制多边形失败：{traceback.format_exc()}"

def draw_helix(sketch_name: str, pitch: float, height: float, radius: float, x: float=0, y: float=0) -> str:
    """绘制螺旋线：指定草图/螺距/高度/半径/中心"""
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch:
            return f"失败：草图[{sketch_name}]不存在"
        helix_input = sketch.sketchCurves.sketchHelices.createInput()
        helix_input.setByPitchHeight(
            adsk.core.ValueInput.createByReal(pitch),
            adsk.core.ValueInput.createByReal(height),
            adsk.core.ValueInput.createByReal(radius),
            adsk.fusion.HelixTypes.RightHandedHelixType
        )
        helix = sketch.sketchCurves.sketchHelices.add(helix_input)
        helix.center = adsk.core.Point3D.create(x, y, 0)
        return f"成功：在[{sketch_name}]绘制螺旋线(螺距{pitch}，高度{height}，半径{radius})"
    except:
        return f"绘制螺旋线失败：{traceback.format_exc()}"

def batch_draw(sketch_name: str, shapes: List[Dict[str, Any]]) -> str:
    """AI 批量绘制：传入形状列表，一次性绘制多个图形
    shapes示例：[{"type":"circle","x":0,"y":0,"r":5},{"type":"rect","x1":0,"y1":0,"x2":10,"y2":10}]
    """
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch:
            return f"失败：草图[{sketch_name}]不存在"
        success_count = 0
        for shape in shapes:
            if shape["type"] == "circle":
                draw_circle(sketch_name, shape["x"], shape["y"], shape["r"])
                success_count +=1
            elif shape["type"] == "rect":
                draw_rect(sketch_name, shape["x1"], shape["y1"], shape["x2"], shape["y2"])
                success_count +=1
        return f"批量绘制完成：成功{success_count}个，总{len(shapes)}个"
    except:
        return f"批量绘制失败：{traceback.format_exc()}"

# ==========================
# 模块3：基础建模（拉伸/旋转/扫描/放样，支持新体/切除/合并）
# ==========================
def extrude(sketch_name: str, distance: float, op_type: str = "new", feat_name: str = "extrude") -> str:
    """拉伸：指定草图/深度/操作类型/特征名
    op_type: new(新体) / cut(切除) / join(合并)
    """
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch or sketch.profiles.count == 0:
            return f"失败：草图[{sketch_name}]无轮廓"
        # 映射操作类型
        op_map = {
            "new": adsk.fusion.FeatureOperations.NewBodyFeatureOperation,
            "cut": adsk.fusion.FeatureOperations.CutFeatureOperation,
            "join": adsk.fusion.FeatureOperations.JoinFeatureOperation
        }
        if op_type not in op_map:
            return f"失败：操作类型仅支持new/cut/join"
        # 创建拉伸
        prof = sketch.profiles.item(0)
        ext_input = features.extrudeFeatures.createInput(prof, op_map[op_type])
        ext_input.setDistanceExtent(False, adsk.core.ValueInput.createByReal(distance))
        ext_feat = features.extrudeFeatures.add(ext_input)
        ext_feat.name = feat_name
        obj_cache["features"][feat_name] = ext_feat.id
        # 更新体缓存
        for body in root_comp.bRepBodies:
            obj_cache["bodies"][body.name] = body.id
        return f"成功：创建拉伸[{feat_name}]，深度{distance}，类型{op_type}"
    except:
        return f"拉伸失败：{traceback.format_exc()}"

def revolve(sketch_name: str, axis_plane: str, angle: float, op_type: str = "new", feat_name: str = "revolve") -> str:
    """旋转：指定草图/旋转轴/角度/操作类型
    axis_plane: x(绕X轴) / y(绕Y轴) / z(绕Z轴)
    """
    try:
        sketch = select_obj("sketch", sketch_name)
        if not sketch or sketch.profiles.count == 0:
            return f"失败：草图[{sketch_name}]无轮廓"
        # 映射旋转轴
        axis_map = {"x": root_comp.xAxis, "y": root_comp.yAxis, "z": root_comp.zAxis}
        op_map = {
            "new": adsk.fusion.FeatureOperations.NewBodyFeatureOperation,
            "cut": adsk.fusion.FeatureOperations.CutFeatureOperation,
            "join": adsk.fusion.FeatureOperations.JoinFeatureOperation
        }
        if axis_plane not in axis_map or op_type not in op_map:
            return f"失败：轴仅支持x/y/z，操作类型仅支持new/cut/join"
        # 创建旋转
        prof = sketch.profiles.item(0)
        rev_input = features.revolveFeatures.createInput(prof, axis_map[axis_plane], op_map[op_type])
        rev_input.setAngleExtent(False, adsk.core.ValueInput.createByReal(math.radians(angle)))
        rev_feat = features.revolveFeatures.add(rev_input)
        rev_feat.name = feat_name
        obj_cache["features"][feat_name] = rev_feat.id
        return f"成功：创建旋转[{feat_name}]，角度{angle}°，绕{axis_plane}轴"
    except:
        return f"旋转失败：{traceback.format_exc()}"

def sweep(profile_sketch: str, path_sketch: str, op_type: str = "new", feat_name: str = "sweep") -> str:
    """扫掠：指定轮廓草图/路径草图/操作类型"""
    try:
        prof_sketch = select_obj("sketch", profile_sketch)
        path_sketch = select_obj("sketch", path_sketch)
        if not prof_sketch or not path_sketch or prof_sketch.profiles.count == 0:
            return f"失败：轮廓/路径草图不存在或无轮廓"
        op_map = {
            "new": adsk.fusion.FeatureOperations.NewBodyFeatureOperation,
            "cut": adsk.fusion.FeatureOperations.CutFeatureOperation,
            "join": adsk.fusion.FeatureOperations.JoinFeatureOperation
        }
        if op_type not in op_map:
            return f"失败：操作类型仅支持new/cut/join"
        # 创建扫掠
        prof = prof_sketch.profiles.item(0)
        path = features.createPath(path_sketch.sketchCurves)
        sweep_input = features.sweepFeatures.createInput(prof, path, op_map[op_type])
        sweep_feat = features.sweepFeatures.add(sweep_input)
        sweep_feat.name = feat_name
        obj_cache["features"][feat_name] = sweep_feat.id
        return f"成功：创建扫掠[{feat_name}]，轮廓[{profile_sketch}]，路径[{path_sketch}]"
    except:
        return f"扫掠失败：{traceback.format_exc()}"

def loft(sketch_names: List[str], op_type: str = "new", feat_name: str = "loft") -> str:
    """放样：指定多个轮廓草图列表/操作类型（AI 核心复杂建模能力）"""
    try:
        # 验证所有草图
        profs = []
        for sn in sketch_names:
            sketch = select_obj("sketch", sn)
            if not sketch or sketch.profiles.count == 0:
                return f"失败：草图[{sn}]不存在或无轮廓"
            profs.append(sketch.profiles.item(0))
        # 映射操作类型
        op_map = {
            "new": adsk.fusion.FeatureOperations.NewBodyFeatureOperation,
            "cut": adsk.fusion.FeatureOperations.CutFeatureOperation,
            "join": adsk.fusion.FeatureOperations.JoinFeatureOperation
        }
        if op_type not in op_map:
            return f"失败：操作类型仅支持new/cut/join"
        # 创建放样
        loft_sections = adsk.core.ObjectCollection.create()
        for p in profs:
            loft_sections.add(p)
        loft_input = features.loftFeatures.createInput(loft_sections)
        loft_feat = features.loftFeatures.add(loft_input)
        loft_feat.name = feat_name
        obj_cache["features"][feat_name] = loft_feat.id
        return f"成功：创建放样[{feat_name}]，轮廓草图{sketch_names}"
    except:
        return f"放样失败：{traceback.format_exc()}"

# 快速基础体创建（AI 常用快捷函数，封装草图+拉伸）
def create_box(name: str, x: float, y: float, z: float, origin_x: float=0, origin_y: float=0) -> str:
    """快捷创建长方体：指定名称/尺寸/原点，自动创建草图+拉伸"""
    try:
        # 自动创建草图
        sketch = create_sketch("xy", f"box_sketch_{name}")
        if "失败" in sketch:
            return sketch
        # 绘制矩形
        draw_rect(f"box_sketch_{name}", origin_x, origin_y, origin_x+x, origin_y+y)
        # 拉伸
        res = extrude(f"box_sketch_{name}", z, "new", name)
        # 重命名体
        for body in root_comp.bRepBodies:
            if body.name == "Body":
                body.name = name
                obj_cache["bodies"][name] = body.id
                break
        return res.replace("extrude", f"长方体[{name}]")
    except:
        return f"创建长方体失败：{traceback.format_exc()}"

def create_cylinder(name: str, radius: float, height: float, origin_x: float=0, origin_y: float=0) -> str:
    """快捷创建圆柱体：指定名称/半径/高度/原点，自动创建草图+拉伸"""
    try:
        sketch = create_sketch("xy", f"cyl_sketch_{name}")
        if "失败" in sketch:
            return sketch
        draw_circle(f"cyl_sketch_{name}", origin_x, origin_y, radius)
        res = extrude(f"cyl_sketch_{name}", height, "new", name)
        for body in root_comp.bRepBodies:
            if body.name == "Body":
                body.name = name
                obj_cache["bodies"][name] = body.id
                break
        return res.replace("extrude", f"圆柱体[{name}]")
    except:
        return f"创建圆柱体失败：{traceback.format_exc()}"

def create_sphere(name: str, radius: float, origin_x: float=0, origin_y: float=0) -> str:
    """快捷创建球体：指定名称/半径/原点，自动创建草图+旋转"""
    try:
        sketch = create_sketch("xz", f"sphere_sketch_{name}")
        if "失败" in sketch:
            return sketch
        draw_circle(f"sphere_sketch_{name}", origin_x, origin_y, radius)
        res = revolve(f"sphere_sketch_{name}", "x", 360, "new", name)
        for body in root_comp.bRepBodies:
            if body.name == "Body":
                body.name = name
                obj_cache["bodies"][name] = body.id
                break
        return res.replace("revolve", f"球体[{name}]")
    except:
        return f"创建球体失败：{traceback.format_exc()}"

# ==========================
# 模块4：高级修改/工业特征（壳体/拔模/螺纹/倒角/圆角/孔）
# ==========================
def create_shell(body_name: str, thickness: float, remove_faces: List[int] = []) -> str:
    """创建壳体（抽壳）：指定体/壁厚/要移除的面索引（默认不移除，封闭空心）"""
    try:
        body = select_obj("body", body_name)
        if not body:
            return f"失败：体[{body_name}]不存在"
        # 选择要移除的面
        remove_face_col = adsk.core.ObjectCollection.create()
        for idx in remove_faces:
            if idx < body.faces.count:
                remove_face_col.add(body.faces.item(idx))
        # 创建壳体
        shell_input = features.shellFeatures.createInput(remove_face_col, True)
        shell_input.insideThickness = adsk.core.ValueInput.createByReal(thickness)
        shell_feat = features.shellFeatures.add(shell_input)
        shell_feat.name = f"shell_{body_name}"
        obj_cache["features"][shell_feat.name] = shell_feat.id
        return f"成功：为[{body_name}]创建壳体，壁厚{thickness}，移除面{remove_faces}"
    except:
        return f"创建壳体失败：{traceback.format_exc()}"

def create_draft(body_name: str, angle: float, face_idxs: List[int], axis: str = "z") -> str:
    """创建拔模（模具斜度）：指定体/角度/要拔模的面索引/拔模轴"""
    try:
        body = select_obj("body", body_name)
        if not body:
            return f"失败：体[{body_name}]不存在"
        # 选择拔模面
        draft_faces = adsk.core.ObjectCollection.create()
        for idx in face_idxs:
            if idx < body.faces.count:
                draft_faces.add(body.faces.item(idx))
        # 映射拔模轴
        axis_map = {"x": root_comp.xAxis, "y": root_comp.yAxis, "z": root_comp.zAxis}
        if axis not in axis_map:
            return f"失败：轴仅支持x/y/z"
        # 创建拔模
        draft_input = features.draftFeatures.createInput(
            draft_faces, axis_map[axis], adsk.core.ValueInput.createByReal(math.radians(angle))
        )
        draft_feat = features.draftFeatures.add(draft_input)
        draft_feat.name = f"draft_{body_name}"
        obj_cache["features"][draft_feat.name] = draft_feat.id
        return f"成功：为[{body_name}]创建拔模，角度{angle}°，面{face_idxs}，绕{axis}轴"
    except:
        return f"创建拔模失败：{traceback.format_exc()}"

def create_thread(body_name: str, edge_idx: int, dia: float, length: float, is_external: bool = True) -> str:
    """创建真实螺纹：指定体/边索引/公称直径/长度/内外螺纹（True外螺纹，False内螺纹）"""
    try:
        body = select_obj("body", body_name)
        if not body or edge_idx >= body.edges.count:
            return f"失败：体[{body_name}]不存在或边索引错误"
        edge = body.edges.item(edge_idx)
        # 创建螺纹
        thread_input = features.threadFeatures.createInput(edge, is_external)
        thread_input.diameter = adsk.core.ValueInput.createByReal(dia)
        thread_input.length = adsk.core.ValueInput.createByReal(length)
        thread_input.setThreadStandard(adsk.fusion.ThreadStandards.ISOThreadStandard)
        thread_feat = features.threadFeatures.add(thread_input)
        thread_feat.name = f"thread_{body_name}"
        obj_cache["features"][thread_feat.name] = thread_feat.id
        return f"成功：为[{body_name}]创建{('外' if is_external else '内')}螺纹，直径{dia}，长度{length}"
    except:
        return f"创建螺纹失败：{traceback.format_exc()}"

def create_fillet(body_name: str, edge_idxs: List[int], radius: float) -> str:
    """批量圆角：指定体/边索引列表/半径（AI 批量修改能力）"""
    try:
        body = select_obj("body", body_name)
        if not body:
            return f"失败：体[{body_name}]不存在"
        # 选择圆角边
        fillet_edges = adsk.core.ObjectCollection.create()
        for idx in edge_idxs:
            if idx < body.edges.count:
                fillet_edges.add(body.edges.item(idx))
        # 创建圆角
        fillet_input = features.filletFeatures.createInput(fillet_edges, adsk.core.ValueInput.createByReal(radius))
        fillet_feat = features.filletFeatures.add(fillet_input)
        fillet_feat.name = f"fillet_{body_name}"
        obj_cache["features"][fillet_feat.name] = fillet_feat.id
        return f"成功：为[{body_name}]创建圆角，半径{radius}，边{edge_idxs}"
    except:
        return f"创建圆角失败：{traceback.format_exc()}"

def create_chamfer(body_name: str, edge_idxs: List[int], distance: float) -> str:
    """批量倒角：指定体/边索引列表/距离"""
    try:
        body = select_obj("body", body_name)
        if not body:
            return f"失败：体[{body_name}]不存在"
        chamfer_edges = adsk.core.ObjectCollection.create()
        for idx in edge_idxs:
            if idx < body.edges.count:
                chamfer_edges.add(body.edges.item(idx))
        chamfer_input = features.chamferFeatures.createInput(chamfer_edges, adsk.core.ValueInput.createByReal(distance))
        chamfer_feat = features.chamferFeatures.add(chamfer_input)
        chamfer_feat.name = f"chamfer_{body_name}"
        obj_cache["features"][chamfer_feat.name] = chamfer_feat.id
        return f"成功：为[{body_name}]创建倒角，距离{distance}，边{edge_idxs}"
    except:
        return f"创建倒角失败：{traceback.format_exc()}"

def create_hole(body_name: str, x: float, y: float, z: float, dia: float, depth: float, sketch_name: str = "hole_sketch") -> str:
    """创建孔：指定体/孔中心坐标/直径/深度，自动创建草图+拉伸切除"""
    try:
        body = select_obj("body", body_name)
        if not body:
            return f"失败：体[{body_name}]不存在"
        # 创建草图并绘制圆
        create_sketch("xy", sketch_name)
        draw_circle(sketch_name, x, y, dia/2)
        # 拉伸切除
        res = extrude(sketch_name, depth, "cut", f"hole_{body_name}_{x}_{y}")
        return f"成功：为[{body_name}]创建孔(中心{x},{y},{z}，直径{dia}，深度{depth})"
    except:
        return f"创建孔失败：{traceback.format_exc()}"

def boolean_operation(target_body: str, tool_body: str, op_type: str) -> str:
    """布尔运算：指定目标体/工具体/操作类型
    op_type: join(合并) / cut(减去) / intersect(相交)
    """
    try:
        target = select_obj("body", target_body)
        tool = select_obj("body", tool_body)
        if not target or not tool:
            return f"失败：目标体[{target_body}]或工具体[{tool_body}]不存在"
        # 映射布尔类型
        bool_map = {
            "join": adsk.fusion.BooleanTypes.JoinBooleanType,
            "cut": adsk.fusion.BooleanTypes.CutBooleanType,
            "intersect": adsk.fusion.BooleanTypes.IntersectBooleanType
        }
        if op_type not in bool_map:
            return f"失败：操作类型仅支持join/cut/intersect"
        # 创建布尔运算
        tool_col = adsk.core.ObjectCollection.create()
        tool_col.add(tool)
        bool_input = features.combineFeatures.createInput(target, tool_col, bool_map[op_type])
        bool_feat = features.combineFeatures.add(bool_input)
        bool_feat.name = f"boolean_{op_type}_{target_body}_{tool_body}"
        obj_cache["features"][bool_feat.name] = bool_feat.id
        # 删除工具体缓存
        if tool_body in obj_cache["bodies"]:
            del obj_cache["bodies"][tool_body]
        return f"成功：布尔{op_type}完成，目标体[{target_body}]，工具体[{tool_body}]"
    except:
        return f"布尔运算失败：{traceback.format_exc()}"

